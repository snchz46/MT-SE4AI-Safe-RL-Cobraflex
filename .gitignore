*~

# OS
.DS_Store
Thumbs.db

# ROS2 / colcon workspace artifacts
build/
install/
log/
.colcon/
COLCON_IGNORE

# Per-package build artifacts (in case build/ at root gets overridden by negation)
src/*/build/
src/*/install/
src/*/log/

# Generated ROS2 interface bindings (auto-regenerated by rosidl)
src/*/msg/_*.py
src/*/srv/_*.py
src/*/action/_*.py

# Experimental data — large logs are not version-controlled,
# only their summary CSVs and aggregated tables.
experiments/sim/run_*/raw_logs/
experiments/physical/run_*/raw_logs/
*.bag
*.mcap

# Policy checkpoints — large binary files
policy/checkpoints/*.zip
policy/checkpoints/*.pt
policy/checkpoints/*.pth
!policy/checkpoints/.gitkeep
!policy/checkpoints/checkpoint_registry.csv

# Generated figures (regenerable from data)
manuscript/figures/auto/

# Local configuration
.env
local_config.yaml

# Coverage
.coverage
htmlcov/
.pytest_cache/

# Misc
docs/.phases*
docs/.temp_templates/