        <TD></TD>
        <TD></TD>
        <TD></TD>
        <TD></TD>
        <TD BGCOLOR="#fbf6ff">sim verdicts</TD>
        <TD BGCOLOR="#fbf6ff">phys verdicts<BR/>+ sim-to-real gap</TD>
        <TD BGCOLOR="#fbf6ff">global verdict<BR/>+ defense</TD>
    </TR>

    <!-- =========================================================
         Transversal: Runtime Monitoring (adaptation A3)
         ========================================================= -->
    <TR>
        <TD BGCOLOR="#ffeef0" ALIGN="LEFT"><B>RM (A3)</B> Runtime Monitoring</TD>
        <TD></TD>
        <TD></TD>
        <TD COLSPAN="5" BGCOLOR="#fff5f6" ALIGN="CENTER">
            <I>Logger Node + intervention logs &mdash; transversal across F2-F6</I>
        </TD>
    </TR>

    <!-- =========================================================
         Bottom: traceability matrix progressive fill + gates
         ========================================================= -->
    <TR>
        <TD BGCOLOR="#f0f0f0" ALIGN="LEFT"><B>Traceability matrix (A4)</B></TD>
        <TD BGCOLOR="#fafafa" ALIGN="CENTER">skeleton</TD>
        <TD BGCOLOR="#fafafa" ALIGN="CENTER">H&harr;SR</TD>
        <TD BGCOLOR="#fafafa" ALIGN="CENTER">+ C</TD>
        <TD BGCOLOR="#fafafa" ALIGN="CENTER">+ SC, M</TD>
        <TD BGCOLOR="#fafafa" ALIGN="CENTER">sim verdicts</TD>
        <TD BGCOLOR="#fafafa" ALIGN="CENTER">phys verdicts</TD>
        <TD BGCOLOR="#fafafa" ALIGN="CENTER"><B>close at G6</B></TD>
    </TR>
    <TR>
        <TD BGCOLOR="#222222" ALIGN="LEFT"><FONT COLOR="white"><B>Gate</B></FONT></TD>
        <TD BGCOLOR="#bbbbbb" ALIGN="CENTER"><B>G0</B></TD>
        <TD BGCOLOR="#bbbbbb" ALIGN="CENTER"><B>G1</B></TD>
        <TD BGCOLOR="#bbbbbb" ALIGN="CENTER"><B>G2</B></TD>
        <TD BGCOLOR="#bbbbbb" ALIGN="CENTER"><B>G3</B></TD>
        <TD BGCOLOR="#bbbbbb" ALIGN="CENTER"><B>G4</B></TD>
        <TD BGCOLOR="#bbbbbb" ALIGN="CENTER"><B>G5</B></TD>
        <TD BGCOLOR="#bbbbbb" ALIGN="CENTER"><B>G6</B></TD>
    </TR>

</TABLE>
    >];
